# External CMS Backend Configuration
# Copy this file to .env and update with your actual values

# Backend API URL (your external CMS)
NUXT_PUBLIC_API_BASE_URL=https://retts-webapp-api-dev.retts.cloud

# API Authentication
NUXT_PUBLIC_API_KEY_NAME=Retts-Api-Key
NUXT_PUBLIC_API_KEY_VALUE=your_api_key_here

# Application Environment
NUXT_PUBLIC_APP_ENV=development

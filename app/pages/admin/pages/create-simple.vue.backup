<template>
  <div class="page-builder">
    <!-- Header -->
    <div class="page-header">
      <div class="header-left">
        <Button icon="pi pi-arrow-left" text @click="handleBack" />
        <div>
          <h1>{{ isEdit ? 'Edit Page' : 'Create Page' }}</h1>
          <div v-if="formData.slug" class="page-url-preview">
            <code>/{{ formData.slug }}</code>
          </div>
        </div>
      </div>
      <div class="header-actions">
        <Button
          label="Preview"
          icon="pi pi-eye"
          severity="secondary"
          outlined
          @click="showPreview = true"
        />
        <Button
          label="Save Draft"
          icon="pi pi-save"
          severity="secondary"
          outlined
          :loading="isSaving"
          @click="saveDraft"
        />
        <Button
          label="Publish"
          icon="pi pi-check"
          :loading="isSaving"
          @click="publishPage"
        />
      </div>
    </div>

    <!-- Builder Layout -->
    <div class="builder-layout">
      <!-- Left Column - Main Form -->
      <div class="main-column">
        <!-- Basic Info Card -->
        <Card>
          <template #title>Basic Information</template>
          <template #content>
            <div class="space-y-4">
              <!-- Title -->
              <div class="field">
                <label for="title" class="block font-medium mb-2">
                  Page Title <span class="text-red-500">*</span>
                </label>
                <InputText
                  id="title"
                  v-model="formData.title"
                  placeholder="Enter page title"
                  class="w-full"
                  :class="{ 'p-invalid': errors.title }"
                  @input="handleTitleChange"
                />
                <small v-if="errors.title" class="text-red-500">
                  {{ errors.title }}
                </small>
              </div>

              <!-- Slug -->
              <div class="field">
                <label for="slug" class="block font-medium mb-2">
                  URL Slug <span class="text-red-500">*</span>
                </label>
                <div class="slug-input-group">
                  <span class="slug-prefix">/</span>
                  <InputText
                    id="slug"
                    v-model="formData.slug"
                    placeholder="page-url-slug"
                    class="flex-1"
                    :class="{ 'p-invalid': errors.slug }"
                  />
                  <Button
                    icon="pi pi-refresh"
                    outlined
                    size="small"
                    v-tooltip.top="'Generate from title'"
                    @click="regenerateSlug"
                  />
                </div>
                <small v-if="errors.slug" class="text-red-500">
                  {{ errors.slug }}
                </small>
              </div>
            </div>
          </template>
        </Card>

        <!-- Content Editor Card -->
        <Card class="mt-4">
          <template #title>Page Content</template>
          <template #content>
            <Tabs v-model="activeTab" class="content-editor-tabs">
              <TabList>
                <Tab value="visual">Visual Editor</Tab>
                <Tab value="html">HTML Editor</Tab>
              </TabList>

              <TabPanels>
                <!-- Visual Editor -->
                <TabPanel value="visual">
                  <div class="visual-editor">
                    <Message
                      v-if="formData.blocks.length === 0"
                      severity="info"
                      :closable="false"
                      class="mb-4"
                    >
                      <div class="flex items-center gap-2">
                        <i class="pi pi-info-circle"></i>
                        <span>Start building your page by adding blocks.</span>
                      </div>
                    </Message>

                    <Button
                      label="Add Block"
                      icon="pi pi-plus"
                      outlined
                      class="mb-4"
                      @click="showBlockSelector = true"
                    />

                    <!-- Blocks List -->
                    <div v-if="formData.blocks.length > 0" class="blocks-list">
                      <div
                        v-for="(block, index) in formData.blocks"
                        :key="block.instanceId"
                        class="block-item"
                      >
                        <div class="block-header">
                          <div class="flex items-center gap-2">
                            <Button
                              icon="pi pi-bars"
                              text
                              size="small"
                              class="drag-handle"
                            />
                            <span class="font-medium">{{ block.name }}</span>
                            <Badge
                              :value="block.component"
                              severity="secondary"
                            />
                          </div>
                          <div class="block-actions">
                            <Button
                              icon="pi pi-pencil"
                              text
                              size="small"
                              v-tooltip.top="'Edit Block'"
                              @click="editBlock(index)"
                            />
                            <Button
                              icon="pi pi-code"
                              text
                              size="small"
                              v-tooltip.top="'Edit HTML'"
                              @click="editBlockHtml(index)"
                            />
                            <Button
                              icon="pi pi-arrow-up"
                              text
                              size="small"
                              :disabled="index === 0"
                              @click="moveBlockUp(index)"
                            />
                            <Button
                              icon="pi pi-arrow-down"
                              text
                              size="small"
                              :disabled="index === formData.blocks.length - 1"
                              @click="moveBlockDown(index)"
                            />
                            <Button
                              icon="pi pi-trash"
                              text
                              size="small"
                              severity="danger"
                              @click="removeBlock(index)"
                            />
                          </div>
                        </div>

                        <!-- Block Preview -->
                        <div class="block-preview">
                          <div class="preview-label">Content:</div>
                          <pre class="preview-content">{{
                            JSON.stringify(block.content, null, 2)
                          }}</pre>

                          <div v-if="block.html" class="mt-2">
                            <div class="preview-label">Custom HTML:</div>
                            <code class="text-xs"
                              >{{ block.html.substring(0, 100) }}...</code
                            >
                          </div>
                        </div>
                      </div>
                    </div>
                  </div>
                </TabPanel>

                <!-- HTML Editor -->
                <TabPanel value="html">
                  <div class="space-y-4">
                    <Message severity="warn" :closable="false">
                      <div class="text-sm">
                        Edit the HTML for all blocks combined. Changes here will
                        override individual block content.
                      </div>
                    </Message>

                    <Textarea
                      v-model="pageHtml"
                      rows="25"
                      class="w-full font-mono text-sm"
                      placeholder="<div>Your page HTML...</div>"
                    />

                    <div class="flex gap-2">
                      <Button
                        label="Apply HTML to Blocks"
                        icon="pi pi-check"
                        size="small"
                        @click="applyHtmlToBlocks"
                      />
                      <Button
                        label="Generate from Blocks"
                        icon="pi pi-refresh"
                        severity="secondary"
                        size="small"
                        outlined
                        @click="generateHtmlFromBlocks"
                      />
                    </div>
                  </div>
                </TabPanel>
              </TabPanels>
            </Tabs>
          </template>
        </Card>
      </div>

      <!-- Right Column - Settings -->
      <div class="sidebar-column">
        <!-- Status Card -->
        <Card>
          <template #title>Publish</template>
          <template #content>
            <div class="space-y-4">
              <div class="field">
                <label for="status" class="block font-medium mb-2"
                  >Status</label
                >
                <Select
                  inputId="status"
                  v-model="formData.status"
                  :options="statusOptions"
                  optionLabel="label"
                  optionValue="value"
                  class="w-full"
                />
              </div>

              <div v-if="formData.status === 'scheduled'" class="field">
                <label for="scheduledAt" class="block font-medium mb-2">
                  Schedule Date
                </label>
                <DatePicker
                  inputId="scheduledAt"
                  v-model="formData.scheduledAt"
                  showTime
                  hourFormat="24"
                  class="w-full"
                />
              </div>

              <div v-if="formData.publishedAt" class="text-sm text-surface-500">
                <strong>Published:</strong>
                {{ new Date(formData.publishedAt).toLocaleString() }}
              </div>
            </div>
          </template>
        </Card>

        <!-- SEO Settings Card (from existing PageSEOFields) -->
        <PageSEOFields v-model="formData.seo" class="mt-4" />
      </div>
    </div>

    <!-- Block Selector Dialog -->
    <Dialog
      v-model:visible="showBlockSelector"
      modal
      header="Add Block"
      :style="{ width: '60rem' }"
    >
      <div class="block-selector">
        <InputText
          v-model="blockSearchQuery"
          placeholder="Search blocks..."
          class="w-full mb-4"
        >
          <template #prefix>
            <i class="pi pi-search" />
          </template>
        </InputText>

        <div class="blocks-grid">
          <div
            v-for="blockDef in availableBlocks"
            :key="blockDef.id"
            class="block-card"
            @click="addBlock(blockDef)"
          >
            <div class="block-icon">
              <i :class="`pi ${blockDef.icon || 'pi-box'}`"></i>
            </div>
            <div class="block-info">
              <div class="font-medium">{{ blockDef.name }}</div>
              <div class="text-xs text-surface-500">
                {{ blockDef.component }}
              </div>
              <div class="text-xs text-surface-400 mt-1">
                {{ blockDef.description }}
              </div>
            </div>
          </div>
        </div>
      </div>
    </Dialog>

    <!-- Block Editor Dialog -->
    <Dialog
      v-model:visible="showBlockEditor"
      modal
      :header="`Edit Block: ${editingBlock?.name}`"
      :style="{ width: '50rem' }"
    >
      <div v-if="editingBlock" class="space-y-4">
        <Tabs value="0">
          <TabList>
            <Tab value="0">Content</Tab>
            <Tab value="1">Props</Tab>
          </TabList>

          <TabPanels>
            <!-- Content Tab -->
            <TabPanel value="0">
              <div class="space-y-4">
                <Message severity="info" :closable="false">
                  Edit the content data for this block
                </Message>
                <Textarea
                  v-model="editingBlockContentJson"
                  rows="12"
                  class="w-full font-mono text-sm"
                  placeholder="{}"
                />
              </div>
            </TabPanel>

            <!-- Props Tab -->
            <TabPanel value="1">
              <div class="space-y-4">
                <Message severity="info" :closable="false">
                  Edit the component properties (styling, configuration)
                </Message>
                <Textarea
                  v-model="editingBlockPropsJson"
                  rows="12"
                  class="w-full font-mono text-sm"
                  placeholder="{}"
                />
              </div>
            </TabPanel>
          </TabPanels>
        </Tabs>
      </div>

      <template #footer>
        <Button
          label="Cancel"
          text
          severity="secondary"
          @click="showBlockEditor = false"
        />
        <Button label="Save" @click="saveBlockEdit" />
      </template>
    </Dialog>

    <!-- Block HTML Editor Dialog -->
    <Dialog
      v-model:visible="showBlockHtmlEditor"
      modal
      :header="`Edit HTML: ${editingBlock?.name}`"
      :style="{ width: '60rem' }"
    >
      <div v-if="editingBlock" class="space-y-4">
        <Message severity="warn" :closable="false">
          <div class="text-sm">
            Override the block's default HTML. Use
            <code>{{ '{{' }}content.field}}</code> and
            <code>{{ '{{' }}props.property}}</code> to reference values.
          </div>
        </Message>

        <Textarea
          v-model="editingBlockHtml"
          rows="20"
          class="w-full font-mono text-sm"
          placeholder="<div>Custom HTML...</div>"
        />
      </div>

      <template #footer>
        <Button
          label="Clear HTML"
          text
          severity="secondary"
          @click="editingBlockHtml = ''"
        />
        <Button label="Cancel" text @click="showBlockHtmlEditor = false" />
        <Button label="Save" @click="saveBlockHtml" />
      </template>
    </Dialog>

    <!-- Unsaved Changes Dialog -->
    <Dialog
      v-model:visible="showUnsavedDialog"
      modal
      header="Unsaved Changes"
      :style="{ width: '32rem' }"
    >
      <p>You have unsaved changes. Do you want to save before leaving?</p>
      <template #footer>
        <Button
          label="Don't Save"
          text
          severity="secondary"
          @click="leaveWithoutSaving"
        />
        <Button label="Cancel" text @click="showUnsavedDialog = false" />
        <Button label="Save" @click="saveAndLeave" />
      </template>
    </Dialog>
  </div>
</template>

<script setup lang="ts">
import type {
  PageFormData,
  PageValidationErrors,
} from '~/utils/types/admin/page.types';
import type { BlockInstance } from '~/utils/types/admin/block.types';
import type { BlockDefinition } from '#shared/types';
import PageSEOFields from '~/components/admin/pages/PageSEOFields.vue';

definePageMeta({
  layout: 'admin',
  middleware: ['admin'],
});

const route = useRoute();
const router = useRouter();

// State
const isEdit = computed(() => !!route.params.id);
const isSaving = ref(false);
const hasChanges = ref(false);
const activeTab = ref('visual');
const showBlockSelector = ref(false);
const showBlockEditor = ref(false);
const showBlockHtmlEditor = ref(false);
const showUnsavedDialog = ref(false);
const blockSearchQuery = ref('');
const errors = ref<PageValidationErrors>({});

const formData = ref<PageFormData>({
  title: '',
  slug: '',
  status: 'draft',
  blocks: [],
  seo: {
    metaTitle: '',
    metaDescription: '',
    keywords: '',
    noIndex: false,
  },
});

const pageHtml = ref('');
const editingBlockIndex = ref<number | null>(null);
const editingBlock = ref<BlockInstance | null>(null);
const editingBlockContentJson = ref('{}');
const editingBlockPropsJson = ref('{}');
const editingBlockHtml = ref('');

// Available blocks (mock - should come from API)
const availableBlocks = ref<BlockDefinition[]>([
  {
    id: '1',
    name: 'Hero Section',
    slug: 'hero-section',
    category: 'layout',
    description: 'Hero banner with title and CTA',
    icon: 'pi-image',
    component: 'HeroBlock',
    defaultContent: { title: 'Welcome', subtitle: 'Your subtitle here' },
    defaultProps: { class: 'py-16' },
    propsSchema: {},
    contentSchema: {},
    isActive: true,
  },
  {
    id: '2',
    name: 'Text Block',
    slug: 'text-block',
    category: 'content',
    description: 'Simple text content',
    icon: 'pi-align-left',
    component: 'TextBlock',
    defaultContent: { text: 'Your text here' },
    defaultProps: {},
    propsSchema: {},
    contentSchema: {},
    isActive: true,
  },
]);

const statusOptions = [
  { label: 'Draft', value: 'draft' },
  { label: 'Published', value: 'published' },
  { label: 'Scheduled', value: 'scheduled' },
];

// Watch for changes
watch(
  formData,
  () => {
    hasChanges.value = true;
  },
  { deep: true },
);

// Methods
const handleTitleChange = () => {
  if (!isEdit.value && !formData.value.slug) {
    regenerateSlug();
  }
};

const regenerateSlug = () => {
  formData.value.slug = formData.value.title
    .toLowerCase()
    .replace(/[^a-z0-9]+/g, '-')
    .replace(/^-+|-+$/g, '');
};

const addBlock = (blockDef: BlockDefinition) => {
  const newBlock: BlockInstance = {
    instanceId: `block-${Date.now()}-${Math.random()}`,
    blockDefinitionId: blockDef.id,
    name: blockDef.name,
    component: blockDef.component,
    props: { ...blockDef.defaultProps },
    content: { ...blockDef.defaultContent },
    sortOrder: formData.value.blocks.length,
  };

  formData.value.blocks.push(newBlock);
  showBlockSelector.value = false;
};

const editBlock = (index: number) => {
  editingBlockIndex.value = index;
  editingBlock.value = { ...formData.value.blocks[index] };
  editingBlockContentJson.value = JSON.stringify(
    editingBlock.value.content || {},
    null,
    2,
  );
  editingBlockPropsJson.value = JSON.stringify(
    editingBlock.value.props || {},
    null,
    2,
  );
  showBlockEditor.value = true;
};

const saveBlockEdit = () => {
  if (editingBlockIndex.value === null || !editingBlock.value) return;

  try {
    editingBlock.value.content = JSON.parse(editingBlockContentJson.value);
    editingBlock.value.props = JSON.parse(editingBlockPropsJson.value);
    formData.value.blocks[editingBlockIndex.value] = editingBlock.value;
    showBlockEditor.value = false;
  } catch (e) {
    alert('Invalid JSON');
  }
};

const editBlockHtml = (index: number) => {
  editingBlockIndex.value = index;
  editingBlock.value = { ...formData.value.blocks[index] };
  editingBlockHtml.value = editingBlock.value.html || '';
  showBlockHtmlEditor.value = true;
};

const saveBlockHtml = () => {
  if (editingBlockIndex.value === null || !editingBlock.value) return;

  editingBlock.value.html = editingBlockHtml.value;
  formData.value.blocks[editingBlockIndex.value] = editingBlock.value;
  showBlockHtmlEditor.value = false;
};

const removeBlock = (index: number) => {
  formData.value.blocks.splice(index, 1);
  // Update sortOrder
  formData.value.blocks.forEach((block, i) => {
    block.sortOrder = i;
  });
};

const moveBlockUp = (index: number) => {
  if (index === 0) return;
  [formData.value.blocks[index], formData.value.blocks[index - 1]] = [
    formData.value.blocks[index - 1],
    formData.value.blocks[index],
  ];
  formData.value.blocks.forEach((block, i) => {
    block.sortOrder = i;
  });
};

const moveBlockDown = (index: number) => {
  if (index === formData.value.blocks.length - 1) return;
  [formData.value.blocks[index], formData.value.blocks[index + 1]] = [
    formData.value.blocks[index + 1],
    formData.value.blocks[index],
  ];
  formData.value.blocks.forEach((block, i) => {
    block.sortOrder = i;
  });
};

const generateHtmlFromBlocks = () => {
  pageHtml.value = formData.value.blocks
    .map((block) => block.html || `<!-- ${block.name} -->`)
    .join('\n\n');
};

const applyHtmlToBlocks = () => {
  // Simple implementation - could be more sophisticated
  const htmlParts = pageHtml.value.split('<!--').filter(Boolean);
  // Apply to blocks or create single HTML block
  alert('HTML applied to page');
};

const validateForm = (): boolean => {
  errors.value = {};
  let isValid = true;

  if (!formData.value.title.trim()) {
    errors.value.title = 'Title is required';
    isValid = false;
  }

  if (!formData.value.slug.trim()) {
    errors.value.slug = 'Slug is required';
    isValid = false;
  }

  return isValid;
};

const saveDraft = async () => {
  formData.value.status = 'draft';
  await savePage();
};

const publishPage = async () => {
  formData.value.status = 'published';
  formData.value.publishedAt = new Date().toISOString();
  await savePage();
};

const savePage = async () => {
  if (!validateForm()) return;

  isSaving.value = true;
  try {
    // TODO: API call
    // const result = await $fetch('/api/admin/pages', {
    //   method: isEdit.value ? 'PUT' : 'POST',
    //   body: formData.value,
    // });

    hasChanges.value = false;
    await navigateTo('/admin/pages');
  } catch (error) {
    console.error('Save error:', error);
  } finally {
    isSaving.value = false;
  }
};

const handleBack = () => {
  if (hasChanges.value) {
    showUnsavedDialog.value = true;
  } else {
    navigateTo('/admin/pages');
  }
};

const saveAndLeave = async () => {
  await savePage();
};

const leaveWithoutSaving = () => {
  hasChanges.value = false;
  navigateTo('/admin/pages');
};

// Lifecycle
onMounted(async () => {
  if (isEdit.value) {
    // TODO: Load page data
    hasChanges.value = false;
  }
});

onBeforeRouteLeave((to, from, next) => {
  if (hasChanges.value) {
    showUnsavedDialog.value = true;
    next(false);
  } else {
    next();
  }
});
</script>

<style scoped>
.page-create-simple-container {
  padding: 2rem;
  max-width: 1400px;
  margin: 0 auto;
}

.page-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 2rem;
}

.header-left {
  display: flex;
  align-items: center;
  gap: 1rem;
}

.header-left h1 {
  font-size: 2rem;
  font-weight: 700;
  margin: 0;
}

.page-url-preview {
  font-size: 0.875rem;
  color: var(--surface-500);
  margin-top: 0.25rem;
}

.header-actions {
  display: flex;
  gap: 0.75rem;
}

.page-content {
  display: grid;
  grid-template-columns: 1fr 360px;
  gap: 1.5rem;
}

.main-column {
  min-width: 0;
}

.space-y-4 > * + * {
  margin-top: 1rem;
}

.slug-input-group {
  display: flex;
  gap: 0.5rem;
  align-items: center;
}

.slug-prefix {
  padding: 0.5rem 0.75rem;
  background: var(--surface-100);
  border: 1px solid var(--surface-300);
  border-radius: 6px;
  font-weight: 500;
}

.blocks-list {
  display: flex;
  flex-direction: column;
  gap: 1rem;
}

.block-item {
  border: 1px solid var(--surface-200);
  border-radius: 8px;
  padding: 1rem;
  background: var(--surface-0);
}

.block-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 0.75rem;
}

.block-actions {
  display: flex;
  gap: 0.25rem;
}

.block-preview {
  background: var(--surface-50);
  padding: 0.75rem;
  border-radius: 6px;
  font-size: 0.875rem;
}

.preview-label {
  font-weight: 600;
  margin-bottom: 0.5rem;
  color: var(--surface-700);
}

.preview-content {
  font-family: 'Courier New', monospace;
  font-size: 0.75rem;
  color: var(--surface-600);
  max-height: 150px;
  overflow: auto;
}

.block-selector .blocks-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
  gap: 1rem;
}

.block-card {
  padding: 1rem;
  border: 1px solid var(--surface-200);
  border-radius: 8px;
  cursor: pointer;
  transition: all 0.2s;
}

.block-card:hover {
  border-color: var(--primary-color);
  background: var(--primary-50);
  transform: translateY(-2px);
}

.block-icon {
  font-size: 2rem;
  color: var(--primary-color);
  margin-bottom: 0.5rem;
}

@media (max-width: 1024px) {
  .page-content {
    grid-template-columns: 1fr;
  }
}
</style>
